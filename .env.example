# MongoDB
MONGO_URI=mongodb://mongo:27017/url_shortener

# Redis
REDIS_URL=redis://redis:6379

# Server
PORT=5000
BASE_URL=http://localhost:5000

# JWT
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Rate Limiting
RATE_LIMIT_REDIRECT_MAX=100
RATE_LIMIT_REDIRECT_WINDOW_SECONDS=60
RATE_LIMIT_CREATE_MAX=20
RATE_LIMIT_CREATE_WINDOW_SECONDS=60

# Cache
CACHE_TTL_SECONDS=300
